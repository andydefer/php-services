{
    "name": "andydefer/php-services",
    "description": "Collection of reusable services for PHP and Laravel applications including model transformation, caching, and common business logic",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AndyDefer\\PhpServices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\PhpServices\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "andydefer/php-vo": "^0.12.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "vimeo/psalm": "^6.14",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "symfony/var-dumper": "^8.1"
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=unit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
