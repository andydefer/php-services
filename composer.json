{
    "name": "andydefer/php-services",
    "description": "Collection of reusable services for PHP and Laravel applications including model transformation, caching, and common business logic",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AndyDefer\\PhpServices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\PhpServices\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "andydefer/domain-structures": "^1.16",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/php-vo": "^0.5.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "composer/composer": "^2.0",
        "larastan/larastan": "^3.8",
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.8",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "symfony/var-dumper": "^7.0",
        "vimeo/psalm": "^6.14"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andydefer\\PhpServices\\PhpServiceServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=unit",
        "test-integration": "phpunit --testsuite=integration"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}